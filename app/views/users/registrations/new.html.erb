<h2 class="mb-2 text-2xl font-semibold text-zinc-900">Criar conta</h2>
<p class="mb-6 text-sm text-zinc-600">
  Plano selecionado: <strong><%= @selected_plan&.name || "Pro" %></strong>
</p>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
  <%= render "users/shared/error_messages", resource: resource %>
  <%= hidden_field_tag "user[plan]", @selected_plan&.name.to_s.downcase %>

  <div>
    <%= f.label :email, class: "mb-1 block text-sm font-medium text-zinc-700" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full rounded-lg border border-zinc-300 px-3 py-2" %>
  </div>

  <div>
    <%= f.label :password, class: "mb-1 block text-sm font-medium text-zinc-700" %>
    <% if @minimum_password_length %>
      <p class="mb-1 text-xs text-zinc-500">(<%= @minimum_password_length %> caracteres minimo)</p>
    <% end %>
    <%= f.password_field :password, autocomplete: "new-password", class: "w-full rounded-lg border border-zinc-300 px-3 py-2" %>
  </div>

  <div>
    <%= f.label :password_confirmation, class: "mb-1 block text-sm font-medium text-zinc-700" %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full rounded-lg border border-zinc-300 px-3 py-2" %>
  </div>

  <div>
    <%= f.submit "Continuar para pagamento", class: "w-full rounded-lg bg-[#1A6FFF] px-4 py-2.5 font-semibold text-white hover:bg-[#4D8FFF]" %>
  </div>
<% end %>

<%= render "users/shared/links" %>
