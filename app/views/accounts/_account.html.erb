<%# Detalhes da conta (show) %>
<div id="<%= dom_id account %>" class="app-card overflow-hidden">
  <dl class="grid divide-y divide-zinc-100 sm:grid-cols-3 sm:divide-x sm:divide-y-0">
    <div class="px-5 py-4 sm:px-6 sm:py-5">
      <dt class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Nome</dt>
      <dd class="mt-1 text-base font-medium text-zinc-900"><%= account.name %></dd>
    </div>
    <div class="px-5 py-4 sm:px-6 sm:py-5">
      <dt class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Plano</dt>
      <dd class="mt-1 text-base font-medium text-zinc-900">
        <% if account.plan %>
          <%= link_to account.plan.name, plan_path(account.plan), class: "text-accent no-underline hover:text-teal-700" %>
        <% else %>
          —
        <% end %>
      </dd>
    </div>
    <div class="px-5 py-4 sm:px-6 sm:py-5">
      <dt class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Status</dt>
      <dd class="mt-1">
        <% if account.active? %>
          <span class="inline-flex rounded-md bg-teal-50 px-2.5 py-1 text-sm font-medium text-teal-800 ring-1 ring-inset ring-teal-600/20">Ativa</span>
        <% else %>
          <span class="inline-flex rounded-md bg-zinc-100 px-2.5 py-1 text-sm font-medium text-zinc-600">Inativa</span>
        <% end %>
      </dd>
    </div>
  </dl>
  <div class="border-t border-zinc-100 px-5 py-4 sm:px-6 sm:py-5">
    <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Descrição</p>
    <p class="mt-2 whitespace-pre-wrap text-sm leading-relaxed text-zinc-700"><%= account.description.presence || "—" %></p>
  </div>
</div>
