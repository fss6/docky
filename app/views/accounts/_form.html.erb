<%= form_with(model: account, class: "space-y-6") do |form| %>
  <% if account.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-900 shadow-[var(--shadow-card)]" role="alert">
      <% err_n = account.errors.count %>
      <p class="font-medium"><%= err_n %> <%= err_n == 1 ? "erro impediu" : "erros impediram" %> salvar esta conta:</p>
      <ul class="mt-2 list-inside list-disc space-y-0.5 text-red-800">
        <% account.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-5">
    <div>
      <%= form.label :name, "Nome", class: "app-label" %>
      <%= form.text_field :name, class: "app-input", autocomplete: "organization" %>
    </div>

    <div>
      <%= form.label :plan_id, "Plano", class: "app-label" %>
      <%= form.collection_select :plan_id, Plan.order(:name), :id, :name,
            { prompt: "Selecione um plano" },
            class: "app-input" %>
    </div>

    <div class="flex items-center gap-3 rounded-lg border border-zinc-200 bg-zinc-50/80 px-4 py-3">
      <%= form.check_box :active, class: "h-4 w-4 rounded border-zinc-300 text-accent focus:ring-2 focus:ring-accent/25" %>
      <%= form.label :active, "Conta ativa", class: "text-sm font-medium text-zinc-700" %>
    </div>

    <div>
      <%= form.label :description, "Descrição", class: "app-label" %>
      <%= form.text_area :description, rows: 4, class: "app-input min-h-[120px] resize-y" %>
    </div>
  </div>

  <div class="flex flex-col-reverse gap-3 border-t border-zinc-100 pt-6 sm:flex-row sm:justify-end">
    <%= link_to "Cancelar", accounts_path, class: "app-btn-secondary text-center sm:text-left" %>
    <%= form.submit account.persisted? ? "Atualizar conta" : "Criar conta", class: "app-btn-primary cursor-pointer border-0" %>
  </div>
<% end %>
