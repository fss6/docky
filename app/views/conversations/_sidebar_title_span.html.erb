<%# locals: (conversation:, variant:) %>
<% desktop = variant == :desktop %>
<span
  id="<%= desktop ? dom_id(conversation, :sidebar_title_desktop) : dom_id(conversation, :sidebar_title_mobile) %>"
  class="<%= desktop ? "line-clamp-2 font-medium leading-snug" : "line-clamp-2 font-medium" %>"
><%= conversation.title.presence || "Conversa ##{conversation.id}" %></span>
