<%# locals: (institution:) %>
<%= form_with model: institution, class: "space-y-6" do |form| %>
  <% if institution.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-900" role="alert">
      <ul class="list-inside list-disc">
        <% institution.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, "Nome", class: "app-label" %>
    <%= form.text_field :name, class: "app-input", required: true %>
  </div>

  <div class="flex flex-col-reverse gap-3 border-t border-zinc-100 pt-6 sm:flex-row sm:justify-end">
    <%= link_to "Cancelar", institutions_path, class: "app-btn-secondary text-center sm:text-left" %>
    <%= form.submit institution.persisted? ? "Guardar" : "Criar", class: "app-btn-primary cursor-pointer border-0" %>
  </div>
<% end %>
