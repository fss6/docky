<%# locals: message %>
<% if message.user? %>
  <div id="<%= dom_id(message) %>" class="flex flex-col items-end gap-1">
    <div
      class="max-w-[min(100%,32rem)] rounded-2xl rounded-br-md bg-accent px-4 py-2.5 text-[13px] leading-relaxed text-white shadow-sm"
    >
      <%= simple_format message.content, {}, class: "mb-0 whitespace-pre-wrap [&_p]:mb-0" %>
    </div>
    <time class="pr-1 text-[11px] tabular-nums text-zinc-400" datetime="<%= message.created_at.iso8601 %>">
      <%= message.created_at.strftime("%H:%M") %>
    </time>
  </div>
<% else %>
  <div id="<%= dom_id(message) %>" class="flex flex-col items-start gap-1">
    <div class="min-w-0 max-w-[min(100%,40rem)]">
      <%= render "messages/content", message: message %>
      <% if message.sources.present? && !message.streaming %>
        <div class="mt-2 flex flex-wrap gap-2">
          <% message.sources.each do |src| %>
            <% doc_id = src["document_id"] %>
            <% chip_class = "inline-flex max-w-full items-center gap-1 rounded-md border border-zinc-200/90 bg-white px-2 py-1 text-xs text-zinc-700 shadow-sm #{"cursor-pointer transition-colors hover:border-teal-300/80 hover:bg-teal-50/90" if local_assigns[:account] && doc_id.present?}" %>
            <% if local_assigns[:account] && doc_id.present? %>
              <%= link_to document_path(doc_id),
                    class: chip_class,
                    data: { turbo_frame: "_top" },
                    title: "Abrir documento" do %>
                <%= heroicon "document-text", variant: :outline, options: { class: "h-3.5 w-3.5 shrink-0 text-zinc-500", "aria-hidden": "true" } %>
                <span class="min-w-0 truncate"><%= src["file"] %> · p. <%= src["page"].presence || "?" %></span>
              <% end %>
            <% else %>
              <span
                class="<%= chip_class %> cursor-default"
                data-source-file="<%= src["file"] %>"
                data-source-page="<%= src["page"] %>"
                data-chunk-id="<%= src["chunk_id"] %>"
              >
                <%= heroicon "document-text", variant: :outline, options: { class: "h-3.5 w-3.5 shrink-0 text-zinc-500", "aria-hidden": "true" } %>
                <%= src["file"] %> · p. <%= src["page"].presence || "?" %>
              </span>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
    <time class="pl-1 text-[11px] tabular-nums text-zinc-400" datetime="<%= message.created_at.iso8601 %>">
      <%= message.created_at.strftime("%H:%M") %>
    </time>
  </div>
<% end %>
