<div id="<%= dom_id group %>" class="app-card overflow-hidden">
  <dl class="grid divide-y divide-zinc-100 sm:grid-cols-2 sm:divide-x sm:divide-y-0">
    <div class="px-5 py-4 sm:px-6 sm:py-5">
      <dt class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Nome</dt>
      <dd class="mt-1 text-base font-medium text-zinc-900"><%= group.name %></dd>
    </div>
    <div class="px-5 py-4 sm:px-6 sm:py-5">
      <dt class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Conta</dt>
      <dd class="mt-1 text-base font-medium text-zinc-900">
        <% if group.account %>
          <%= link_to group.account.name, account_path(group.account), class: "text-accent no-underline hover:text-teal-700" %>
        <% else %>
          —
        <% end %>
      </dd>
    </div>
  </dl>
</div>
