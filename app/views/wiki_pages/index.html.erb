<% content_for :title, "Base de Conhecimento · Dokivo" %>

<div class="mb-4 rounded-lg border border-blue-100 bg-blue-50/60 px-4 py-3 text-sm text-blue-900">
  <div class="flex items-start gap-2.5">
    <%= heroicon "information-circle", variant: :outline, options: { class: "mt-0.5 h-5 w-5 shrink-0 text-blue-700", "aria-hidden": "true" } %>
    <div>
      <p class="font-medium">Sobre a Base de Conhecimento</p>
      <p class="mt-1 text-blue-800">
        Esta área organiza o conhecimento extraído automaticamente dos documentos da conta para facilitar consultas, revisões e conexões entre temas.
        O conteúdo é atualizado continuamente conforme novos arquivos são processados. Para validações formais, consulte os documentos-fonte.
      </p>
    </div>
  </div>
</div>

<div class="flex h-[calc(100vh-4rem)] gap-0 overflow-hidden rounded-xl border border-zinc-200 bg-white shadow-sm">

  <%# Sidebar de categorias %>
  <aside class="hidden w-64 shrink-0 overflow-y-auto border-r border-zinc-200 bg-zinc-50/60 lg:block">
    <div class="sticky top-0 z-10 border-b border-zinc-200 bg-zinc-50/90 px-4 py-4 backdrop-blur">
      <p class="text-xs font-semibold uppercase tracking-wider text-zinc-500">Categorias</p>
    </div>

    <nav class="px-2 py-3 space-y-0.5">
      <% page_type_labels = { "index" => "Índice", "summary" => "Resumos", "entity" => "Entidades", "synthesis" => "Sínteses" } %>
      <% page_type_icons  = { "index" => "list-bullet", "summary" => "document-text", "entity" => "building-office", "synthesis" => "magnifying-glass" } %>

      <% WikiPage::PAGE_TYPES.each do |type| %>
        <% pages = @pages_by_type[type] %>
        <% next if pages.empty? %>

        <div class="mt-2 first:mt-0">
          <p class="px-2 py-1 text-xs font-semibold uppercase tracking-wider text-zinc-400">
            <%= page_type_labels[type] || type.capitalize %>
          </p>
          <% pages.each do |page| %>
            <%= link_to wiki_path(slug: page.slug),
                  class: "flex items-center gap-2 rounded-md px-2 py-1.5 text-sm transition #{@selected_page&.id == page.id ? 'bg-accent/10 font-medium text-accent' : 'text-zinc-700 hover:bg-zinc-100 hover:text-zinc-900'}" do %>
              <%= heroicon page_type_icons[type] || "document", variant: :outline, options: { class: "h-4 w-4 shrink-0", "aria-hidden": "true" } %>
              <span class="truncate"><%= page.title %></span>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <% if @wiki_pages.empty? %>
        <p class="px-2 py-3 text-xs text-zinc-400">Nenhuma página ainda.</p>
      <% end %>
    </nav>
  </aside>

  <%# Área principal %>
  <main class="flex-1 overflow-y-auto">
    <% if @wiki_pages.any? %>
      <div class="border-b border-zinc-200 bg-white px-4 py-3 lg:hidden">
        <label for="wiki-page-select" class="mb-1 block text-xs font-semibold uppercase tracking-wider text-zinc-500">
          Página
        </label>
        <select
          id="wiki-page-select"
          class="w-full rounded-md border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-800 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20"
          onchange="if (this.value) window.location.href = this.value;">
          <% @wiki_pages.each do |page| %>
            <option value="<%= wiki_path(slug: page.slug) %>" <%= "selected" if @selected_page&.id == page.id %>>
              [<%= page.page_type %>] <%= page.title %>
            </option>
          <% end %>
        </select>
      </div>
    <% end %>

    <% if @selected_page %>
      <%= render "wiki_pages/page_content", page: @selected_page %>
    <% elsif @wiki_pages.any? %>
      <div class="flex h-full items-center justify-center p-8 text-center">
        <div>
          <%= heroicon "book-open", variant: :outline, options: { class: "mx-auto h-12 w-12 text-zinc-300" } %>
          <p class="mt-3 text-sm font-medium text-zinc-900">Selecione uma página</p>
          <p class="mt-1 text-sm text-zinc-500">Escolha uma página na barra lateral para visualizar seu conteúdo.</p>
        </div>
      </div>
    <% else %>
      <div class="flex h-full items-center justify-center p-8 text-center">
        <div>
          <%= heroicon "book-open", variant: :outline, options: { class: "mx-auto h-12 w-12 text-zinc-300" } %>
          <p class="mt-3 text-sm font-medium text-zinc-900">Base de conhecimento vazia</p>
          <p class="mt-1 max-w-sm text-sm text-zinc-500">
            O wiki é gerado automaticamente conforme documentos são processados.
            Faça upload de um documento para começar.
          </p>
          <%= link_to "Ir para documentos", folders_path, class: "mt-4 inline-block app-btn-secondary text-sm" %>
        </div>
      </div>
    <% end %>
  </main>
</div>
